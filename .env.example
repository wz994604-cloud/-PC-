# Neon PostgreSQL pooled connection string. Server-side only; never commit a real value.
DATABASE_URL=

# Long random secret used by cron-job.org as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Verified upstream draw API endpoint.
SOURCE_API_URL=https://pc28.shop/

# Upstream request timeout in milliseconds.
SOURCE_TIMEOUT_MS=10000
