# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build
/dist/

# misc
.DS_Store
*.pem
*.key
*.zip
/upload/
/.git-local/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.tmp
*.temp

# env files (can opt-in for committing if needed)
.env*
*.env
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.data/
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm
